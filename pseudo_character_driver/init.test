#!/bin/sh
# 1. Mount essential pseudo-filesystems
mount -t proc none /proc
mount -t sysfs none /sys

# 2. Mount devtmpfs so the kernel automatically populates device nodes (like ttyAMA0)
mount -t devtmpfs devtmpfs /dev

echo -e "\n=========================================="
echo -e "   Successfully Booted QEMU ARM64 Target   "
echo -e "==========================================\n"

# 3. Load the cdev driver and run its test
echo "Loading pseudo_char.ko..."
insmod /pseudo_char.ko
if [ -f /test_pseudo ]; then
    chmod +x /test_pseudo
    /test_pseudo
fi

dmesg | grep -E "pseudodev"

poweroff -f
